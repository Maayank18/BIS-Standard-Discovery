# ═══════════════════════════════════════════════════════
#  BIS RAG Engine — Environment Configuration
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ── PRIMARY: OpenRouter (RECOMMENDED) ──────────────────
# Get your free API key at: https://openrouter.ai/keys
# Gives access to 100+ models including FREE tiers
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Which model to use via OpenRouter:
# FREE options (no cost, good quality):
#   meta-llama/llama-3.1-8b-instruct:free   ← default, reliable
#   google/gemma-3-27b-it:free              ← stronger, slower
#   mistralai/mistral-7b-instruct:free      ← fast and capable
# PAID options (better quality, small cost):
#   anthropic/claude-haiku-4-5             ← best quality
#   openai/gpt-4o-mini                     ← reliable paid
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Your site info (required for OpenRouter free tier)
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=BIS RAG Engine

# ── FALLBACK: Direct providers (optional) ──────────────
# Only needed if you want to bypass OpenRouter
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-key-here
# GROQ_API_KEY=your-groq-key-here

# ── No LLM (uses fast template rationale) ──────────────
# Uncomment to skip all LLM calls — still fully functional
# for the eval metrics (Hit Rate, MRR, Latency)
# LLM_PROVIDER=none
